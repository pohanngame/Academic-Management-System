# Windows host development mode:
# - MySQL, PaddleOCR, and LibreOffice run in Docker Compose.
# - Spring Boot and Vue/Vite run directly on the Windows host.
# Copy this file to .env for Docker Compose variable substitution.
# Spring Boot does not automatically load this .env file; export the DB_*, APP_*,
# AI_*, OCR_*, and DOCUMENT_CONVERSION_* values into the backend PowerShell process.
# Never commit real passwords, JWT secrets, or API keys.

# Docker MySQL and host-backend database connection.
MYSQL_DATABASE=academic_profile
MYSQL_USER=academic_profile_user
MYSQL_PASSWORD=replace-with-local-dev-password
MYSQL_ROOT_PASSWORD=replace-with-local-root-password
MYSQL_PORT=3306
FRONTEND_PORT=8088
DB_URL=jdbc:mysql://127.0.0.1:3306/academic_profile?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
DB_USERNAME=academic_profile_user
DB_PASSWORD=replace-with-local-dev-password

# Windows host backend and local file storage.
SERVER_PORT=8080
APP_UPLOAD_DIR=./data/uploads
APP_EXPORT_DIR=./data/exports
APP_TEMP_DIR=./data/temp
APP_MAX_UPLOAD_SIZE=10MB
APP_JWT_SECRET=replace-with-random-secret-at-least-32-characters
APP_JWT_EXPIRATION_MINUTES=120

# AI settings. AI_API_KEY is intentionally omitted: provide it only in the
# current backend PowerShell process when real AI generation is required.
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_MAX_TOKENS=1024
AI_MAX_PROMPT_CHARS=30000
AI_TIMEOUT_SECONDS=60

# Optional PDF conversion. The backend timeout is longer than Gotenberg's API timeout.
# DOCUMENT_CONVERSION_* are Spring Boot backend settings; LIBREOFFICE_* configure
# the optional Docker Compose Gotenberg service only.
DOCUMENT_CONVERSION_ENABLED=false
DOCUMENT_CONVERSION_BASE_URL=http://127.0.0.1:3000
DOCUMENT_CONVERSION_CONNECT_TIMEOUT_SECONDS=5
DOCUMENT_CONVERSION_TIMEOUT_SECONDS=70
DOCUMENT_CONVERSION_MAX_INPUT_SIZE=15MB
DOCUMENT_CONVERSION_MAX_OUTPUT_SIZE=20MB
LIBREOFFICE_PORT=3000
LIBREOFFICE_API_BODY_LIMIT=20MB
LIBREOFFICE_API_TIMEOUT=60s
LIBREOFFICE_AUTO_START=true
LIBREOFFICE_START_TIMEOUT=20s
LIBREOFFICE_MAX_QUEUE_SIZE=4
LIBREOFFICE_RESTART_AFTER=10

# Optional OCR. Enable it only after the Compose ocr profile is healthy.
OCR_ENABLED=false
OCR_BASE_URL=http://127.0.0.1:8866
OCR_PORT=8866
OCR_TIMEOUT_SECONDS=60
OCR_MIN_PDF_TEXT_LENGTH=80
OCR_HTTP_PROXY=
OCR_HTTPS_PROXY=
OCR_ALL_PROXY=

# Optional build proxies for backend, frontend, and LibreOffice images.
# Leave empty to override unusable Docker Desktop proxy injection.
BUILD_HTTP_PROXY=
BUILD_HTTPS_PROXY=
BUILD_ALL_PROXY=
